{
    // add from GitHub Gist below...
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.fontSize": 12.5,
    "terminal.integrated.enableMultiLinePasteWarning": "never",
    "editor.bracketPairColorization.enabled": true,
    "workbench.colorTheme": "Owlet (One)",
    "workbench.iconTheme": "vscode-icons",
    "workbench.statusBar.visible": true,
    "workbench.colorCustomizations": {
        // "statusBar.background": "#6b7fa1",
        "statusBar.background": "#6366f1",
        "statusBar.foreground": "#fff",
        "editor.foreground": "#aaa"
    },
    "quarto.cells.background.color": "default",
    "quarto.cells.background.darkDefault": "#d1d1d110",
    "editor.rulers": [80],
    "editor.wordWrap": "bounded",
    "editor.wordWrapColumn": 80,
    "[python]": {
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.wordBasedSuggestions": "off",
        "editor.insertSpaces": true,
        "editor.tabSize": 4
    },
    "[r]": {
        "editor.defaultFormatter": "Posit.air-vscode",

        "editor.formatOnType": true,
        "editor.tabSize": 2,
        "editor.wordSeparators": "`~!@#$%^&*()-=+[{]}\\|;:'\",<>/?",
        "editor.smartSelect.selectLeadingAndTrailingWhitespace": false,
        "editor.wordBasedSuggestions": "off"
    },
    "[markdown]": {
        "editor.unicodeHighlight.ambiguousCharacters": false,
        "editor.unicodeHighlight.invisibleCharacters": false,
        "diffEditor.ignoreTrimWhitespace": false,
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "comments": "off",
            "strings": "off",
            "other": "off"
        },
        "editor.defaultFormatter": "yzhang.markdown-all-in-one"
    },
    "[quarto]": {
        "editor.wordWrap": "on",
        "editor.quickSuggestions": {
            "comments": "on",
            "other": "on",
            "strings": "on"
        },
        "editor.quickSuggestionsDelay": 250,
        "editor.snippetSuggestions": "bottom",
        "editor.wordBasedSuggestions": "off",
        "editor.suggestOnTriggerCharacters": true,
        "editor.unicodeHighlight.ambiguousCharacters": false,
        "editor.unicodeHighlight.invisibleCharacters": false
    },
    "interactiveWindow.executeWithShiftEnter": true,
    "workbench.editorAssociations": {
        "*.qmd": "default",
        "*.docx": "default"
    },
    "quarto.visualEditor.markdownWrap": "column",
    "diffEditor.hideUnchangedRegions.enabled": true,
    "livePreview.showServerStatusNotifications": true,
    "editor.fontFamily": "'Fira Code', Consolas, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "vsicons.dontShowNewVersionMessage": true,
    "workbench.startupEditor": "none",
    "security.workspace.trust.untrustedFiles": "open",
    "quarto.render.renderOnSave": true,
    "terminal.integrated.tabs.location": "left",
    "explorer.confirmDelete": false,
    "git.openRepositoryInParentFolders": "always",
    "terminal.integrated.fontFamily": "monospace",
    "terminal.integrated.stickyScroll.enabled": false,
    "files.associations": {
        "*.qmd": "quarto",
        "renv.lock": "json"
    },
    "editor.fontSize": 12.5,
    "positron.r.kernel.logLevel": "error",
    "positron.r.diagnostics.enable": false,
    "editor.tabSize": 2,
    "explorer.confirmDragAndDrop": false,
    "git.confirmSync": false,
    "diffEditor.codeLens": true,
    "files.autoSaveDelay": 10000,
    "files.dialog.defaultPath": "/home/kyle/dev/",
    "plots.darkFilter": "off",

    // New (May 2025)
    "window.menuBarVisibility": "compact",
    "window.density.editorTabHeight": "compact",
    "editor.scrollbar.verticalScrollbarSize": 5,
    "workbench.keybindings.rstudioKeybindings": true,

    // New (August 2025)
    "editor.minimap.enabled": true,
    "editor.minimap.side": "right",

    "editor.stickyScroll.enabled": true,
    "console.fontSize": 11.5,
    "console.fontFamily": "'Fira Code', Consolas, 'Courier New', monospace",
    "console.fontLigatures": true,
    "files.eol": "\n",
    "workbench.preferredDarkColorTheme": "Owlet (One)",
    "terminal.integrated.persistentSessionScrollback": 1000,
    "terminal.integrated.sendKeybindingsToShell": false,
    "terminal.integrated.commandsToSkipShell": [
        "workbench.view.explorer"
    ],
    "positron.assistant.followups.enable": false,
    "positron.assistant.streamingEdits.enable": false,
    "positron.assistant.consoleActions.enable": false,
    "positron.assistant.gitIntegration.enable": false,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.suggest.enabled": false,
    "terminal.integrated.suggest.inlineSuggestion": "off",
    "terminal.integrated.tabs.enabled": false,
    "projectManager.git.baseFolders": [
        "dev"
    ],
    "claudeCode.preferredLocation": "panel",

    // Claude Code font size
    "chat.fontSize": 14,
    "redhat.telemetry.enabled": false,
    "terminal.integrated.initialHint": false,
    "yaml.schemas": {
        "file:///home/kyle/.positron/extensions/continue.continue-1.3.38-linux-x64/config-yaml-schema.json": [
            ".continue/**/*.yaml"
        ]
    },
    "window.zoomLevel": 1.5,
    "remote.autoForwardPortsSource": "hybrid",
    "positron.r.customRootFolders": [
        "/home/kyle/dev/.Rbin"
    ],
    "positron.r.customBinaries": [
        "/home/kyle/dev/.Rbin/bin/R"
    ],
    "positron.r.interpreters.default": "/home/kyle/dev/.Rbin/bin/R",

    "nix.enableLanguageServer": true,
    "nix.serverPath": "nil",
    "nix.serverSettings": {
        "nil": {
            "formatting": {
                "command": [ "nixfmt" ]
            }
        }
    },
    "[nix]": {
        "editor.quickSuggestions": {
            "other": "on",
            "comments": "off",
            "strings": "on"
        },
        "editor.quickSuggestionsDelay": 10,
        "editor.suggestOnTriggerCharacters": true,
        "editor.acceptSuggestionOnEnter": "on"
    },
    "editor.quickSuggestions": {
        "other": "on",
        "comments": "off",
        "strings": "on"
    },
    "editor.quickSuggestionsDelay": 10,
    "editor.suggestOnTriggerCharacters": true
}
